{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vh", "vw"]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ]
    },
    "color": {
      "palette": [
        { "name": "Primary", "slug": "primary", "color": "#0b5fff" },
        { "name": "Accent", "slug": "accent", "color": "#00c2ff" },
        { "name": "Background", "slug": "background", "color": "#eef6ff" },
        { "name": "Text", "slug": "text", "color": "#22304a" }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "lineHeight": "1.5"
    },
    "color": {
      "background": "#eef6ff",
      "text": "#22304a"
    },
    "spacing": {
      "padding": {
        "top": "12px",
        "right": "16px",
        "bottom": "12px",
        "left": "16px"
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "header-admin",
      "title": "Header Admin",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "footer-admin",
      "title": "Footer Admin",
      "area": "footer"
    }
  ]
}
